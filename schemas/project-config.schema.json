{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ai-commit project config",
  "type": "object",
  "properties": {
    "$schema": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "scopes": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProjectScope"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "hook": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "max_diff_lines": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "no_commit_co_author": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "no_model_co_author": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "ProjectScope": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["name"],
      "additionalProperties": false
    }
  }
}
