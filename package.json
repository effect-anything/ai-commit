{
  "name": "@effect-x/ai-commit",
  "version": "0.0.1",
  "description": "AI commit cli with git and jj support.",
  "keywords": [
    "cli",
    "commit",
    "effect",
    "git",
    "jj",
    "jujutsu",
    "llm"
  ],
  "homepage": "https://github.com/effect-anything/ai-commit",
  "bugs": {
    "url": "https://github.com/effect-anything/ai-commit/issues"
  },
  "license": "MIT",
  "contributors": [
    "xesrevinu"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/effect-anything/ai-commit.git"
  },
  "bin": {
    "ai-commit": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/cli.js",
  "module": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js",
    "./*": "./*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "lefthook install && effect-tsgo patch",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test && bun run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish --provenance",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@effect/ai-openai": "4.0.0-beta.40",
    "@effect/platform-node": "4.0.0-beta.40",
    "@effect/tsgo": "0.0.16",
    "@effect/vitest": "4.0.0-beta.40",
    "@types/node": "^24.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260320.1",
    "effect": "4.0.0-beta.40",
    "lefthook": "^1.11.13",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "tsdown": "^0.15.5",
    "vitest": "^4.1.0",
    "yaml": "^2.8.1"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=24"
  }
}
